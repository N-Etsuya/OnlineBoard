<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="25" xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1" fx:controller="onlineboard.controllers.CreateThreadController">
    <padding>
        <Insets bottom="30" left="30" right="30" top="30"/>
    </padding>
    <children>
        <Label text="スレッドを作成" style="-fx-font-size: 28px; -fx-font-weight: bold;"/>
        <TextField fx:id="titleField" promptText="タイトル" prefWidth="400" prefHeight="40" style="-fx-ime-mode: active;"/>
        <Button fx:id="createButton" onAction="#handleCreate" text="作成" 
                style="-fx-background-color: #4CAF50; -fx-text-fill: white;" prefWidth="250" prefHeight="40"/>
    </children>
</VBox>