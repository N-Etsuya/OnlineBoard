<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="onlineboard.controllers.ThreadListController">
    <padding>
        <Insets bottom="20" left="20" right="20" top="20"/>
    </padding>
    <top>
        <HBox spacing="15"> 
            <Button fx:id="createThreadButton" onAction="#handleCreateThread" text="スレッドを作成" 
                    style="-fx-background-color: #4CAF50; -fx-text-fill: white;" prefHeight="40"/>
            <Button fx:id="refreshButton" onAction="#handleRefresh" text="更新" prefHeight="40"/> 
        </HBox>
    </top>
    <center>
        <TableView fx:id="threadTable">
            <columns>
                <TableColumn fx:id="createdAtColumn" text="作成日時" prefWidth="250"/>
                <TableColumn fx:id="titleColumn" text="タイトル" prefWidth="400"/>
            </columns>
        </TableView>
    </center>
</BorderPane>